generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String       @id @default(cuid())
  name        String
  inventories Inventory[]
}

model Inventory {
  id            String   @id @default(cuid())
  productId     String
  totalUnits    Int
  reservedUnits Int @default(0)

  product Product @relation(fields: [productId], references: [id])
}

model Reservation {
  id         String   @id @default(cuid())
  productId  String
  quantity   Int
  status     String
  expiresAt  DateTime

  product Product @relation(fields: [productId], references: [id])
}
